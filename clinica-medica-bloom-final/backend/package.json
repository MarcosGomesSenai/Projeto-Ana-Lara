{
  "name": "bloom-maternity-backend",
  "version": "1.0.0",
  "description": "API REST para Clínica de Obstetrícia Bloom Maternity",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:watch": "nodemon --watch . server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "seed": "node scripts/seed.js",
    "db:sync": "node scripts/syncDatabase.js",
    "db:reset": "node scripts/resetDatabase.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "keywords": [
    "api",
    "express",
    "mysql",
    "sequelize",
    "obstetricia",
    "clinica",
    "bloom-maternity"
  ],
  "author": "Bloom Maternity Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "mysql2": "^3.6.5",
    "sequelize": "^6.35.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "joi": "^17.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bloom-maternity/bloom-maternity-backend.git"
  },
  "bugs": {
    "url": "https://github.com/bloom-maternity/bloom-maternity-backend/issues"
  },
  "homepage": "https://github.com/bloom-maternity/bloom-maternity-backend#readme"
}